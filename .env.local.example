# ============================================
# SUPABASE - Récupère ces valeurs sur supabase.com
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON_PUBLIQUE

# ============================================
# CONFIGURATION DU CONCOURS - À MODIFIER CHAQUE ANNÉE
# ============================================

# Email admin (peut se connecter au panneau admin)
NEXT_PUBLIC_ADMIN_EMAIL=admin@iai-mbalmayo.cm

# Nom de l'édition du concours
NEXT_PUBLIC_EDITION=2025

# Date de fin des votes (format ISO 8601)
# Exemple : 2025-12-31T23:59:59 = 31 décembre 2025 à minuit
NEXT_PUBLIC_VOTE_END_DATE=2025-12-31T23:59:59

# Date de début des votes
NEXT_PUBLIC_VOTE_START_DATE=2025-10-01T00:00:00
